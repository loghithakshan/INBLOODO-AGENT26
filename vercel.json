{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "HOST": "0.0.0.0",
    "PORT": "8000",
    "DEBUG": "false"
  }
}
